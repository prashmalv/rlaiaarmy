# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
MODEL_NAME=claude-sonnet-4-6

# ── Email (Gmail recommended) ─────────────────────────────────────────────────
# For Gmail: enable 2FA → create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_NAME=RightLeftAI Team

# ── LinkedIn API ──────────────────────────────────────────────────────────────
# Get from: developers.linkedin.com → Create App → OAuth2
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:your-id-here
LINKEDIN_ORGANIZATION_URN=urn:li:organization:your-org-id    # company page

# ── Facebook / Instagram ──────────────────────────────────────────────────────
# Get from: developers.facebook.com → App → Graph API
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── News Intelligence ─────────────────────────────────────────────────────────
# Free API key from newsapi.org (500 requests/day free)
NEWS_API_KEY=

# ── Scheduling ────────────────────────────────────────────────────────────────
DAILY_LEADS_SCAN_TIME=07:00
DAILY_POST_TIME=09:00
DAILY_EMAIL_TIME=10:00

# ── Posting Mode: "manual" queues for review, "auto" posts directly ───────────
POSTING_MODE=manual
